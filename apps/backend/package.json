{
  "name": "semiont-backend",
  "version": "0.4.21",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsup && node --watch --conditions=development dist/index.js",
    "build": "npm run build:app",
    "build:app": "prisma generate && npm run typecheck && tsup",
    "build:clean": "npm run clean && prisma generate && npm run typecheck && tsup",
    "build:fast": "prisma generate && npm run typecheck && tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js",
    "test": "SEMIONT_ENV=unit vitest run",
    "test:watch": "SEMIONT_ENV=unit vitest",
    "test:coverage": "SEMIONT_ENV=unit vitest run --coverage",
    "test:ui": "SEMIONT_ENV=unit vitest --ui",
    "test:unit": "SEMIONT_ENV=unit vitest run --testNamePattern=\"^(?!.*integration).*\"",
    "test:integration": "SEMIONT_ENV=integration vitest run --config=vitest.integration.config.mjs",
    "test:api": "SEMIONT_ENV=unit vitest run src/__tests__/api/admin-endpoints.test.ts src/__tests__/api/documentation.test.ts src/__tests__/middleware/auth.test.ts",
    "test:security": "SEMIONT_ENV=unit vitest run --reporter=verbose --testNamePattern=security",
    "type-check": "tsc --noEmit",
    "rebuild-projections": "tsx src/cli/rebuild-projections.ts",
    "rebuild-graph": "tsx src/cli/rebuild-graph.ts",
    "rebuild-vectors": "tsx src/cli/rebuild-vectors.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.17.1",
    "@hono/swagger-ui": "^0.6.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@semiont/core": "0.4.21",
    "@semiont/event-sourcing": "0.4.21",
    "@semiont/jobs": "0.4.21",
    "@semiont/make-meaning": "0.4.21",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "argon2": "^0.44.0",
    "hono": "^4.8.10",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.3",
    "msw": "^2.10.4",
    "prisma": "^7.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  }
}
