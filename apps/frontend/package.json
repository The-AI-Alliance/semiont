{
  "name": "semiont-frontend",
  "version": "0.4.13",
  "private": true,
  "scripts": {
    "audit:compliance": "./scripts/generate-compliance-report.sh",
    "audit:compliance:tests": "./scripts/generate-test-compliance-report.sh",
    "predev": "node scripts/merge-translations.js",
    "dev": "node scripts/copy-favicons.js && node scripts/copy-pdfjs.js && vite --host",
    "dev:mock": "node scripts/merge-translations.js && node scripts/copy-favicons.js && node scripts/copy-pdfjs.js && node scripts/dev-with-mock.js",
    "dev:fast": "node scripts/merge-translations.js && node scripts/copy-favicons.js && node scripts/copy-pdfjs.js && vite --host",
    "prebuild": "node scripts/merge-translations.js",
    "build": "node scripts/copy-favicons.js && node scripts/copy-pdfjs.js && npm run typecheck && vite build",
    "build:quick": "vite build",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "prestart": "node scripts/merge-translations.js",
    "start": "vite preview --host",
    "pretest": "node scripts/merge-translations.js",
    "test": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest run --reporter=default --reporter=json --outputFile=test-results.json",
    "test:watch": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest",
    "pretest:coverage": "node scripts/merge-translations.js",
    "test:coverage": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest run --coverage",
    "test:ui": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest --ui",
    "test:unit": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest run --reporter=default --reporter=json --outputFile=test-results.json --testNamePattern=\"^(?!.*integration).*\"",
    "test:integration": "SEMIONT_ENV=integration SEMIONT_ROOT=../.. vitest run --reporter=default --reporter=json --outputFile=test-results.json --testNamePattern=\"integration\"",
    "test:security:admin": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest run --reporter=verbose 'src/app/[locale]/admin/__tests__/page.test.tsx' 'src/app/[locale]/admin/__tests__/layout.test.tsx'",
    "test:security:other": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest run --reporter=verbose 'src/app/[locale]/privacy/__tests__/page.test.tsx' src/lib/__tests__/validation.test.ts",
    "pretest:security": "node scripts/merge-translations.js",
    "test:security": "npm run test:security:admin && npm run test:security:other",
    "test:a11y": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest run -t \"Accessibility\"",
    "test:a11y:watch": "SEMIONT_ENV=unit SEMIONT_ROOT=../.. vitest -t \"Accessibility\"",
    "test:typecheck": "vitest typecheck",
    "type-check": "tsc --noEmit",
    "type-check:test": "tsc --noEmit -p tsconfig.test.json",
    "type-check:all": "npm run type-check && npm run type-check:test"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@semiont/api-client": "0.4.13",
    "@semiont/react-ui": "0.4.13",
    "@tanstack/react-query": "^5.90.16",
    "i18next": "^24.2.3",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.7.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.2",
    "axe-core": "^4.11.0",
    "cross-env": "^10.1.0",
    "fast-check": "^4.3.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.0",
    "msw": "^2.10.4",
    "postcss": "^8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "vite": "^6.3.5"
  },
  "msw": {
    "workerDirectory": [
      "apps/frontend/public"
    ]
  }
}
