{
  "name": "@semiont/react-ui",
  "version": "0.3.0",
  "description": "React components and hooks for Semiont",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./test-utils": {
      "types": "./dist/test-utils.d.mts",
      "import": "./dist/test-utils.mjs"
    },
    "./styles": "./src/styles/index.css",
    "./styles/index.css": "./src/styles/index.css",
    "./styles/variables.css": "./src/styles/variables.css",
    "./tailwind": "./src/integrations/tailwind-plugin.js",
    "./integrations/css-modules": {
      "types": "./dist/integrations/css-modules-helper.d.mts",
      "import": "./dist/integrations/css-modules-helper.mjs"
    },
    "./integrations/styled-components": {
      "types": "./dist/integrations/styled-components-theme.d.mts",
      "import": "./dist/integrations/styled-components-theme.mjs"
    },
    "./translations/*": "./translations/*.json"
  },
  "files": [
    "dist",
    "src/styles",
    "src/components",
    "src/features",
    "src/integrations",
    "src/examples",
    "translations",
    "public",
    "README.md"
  ],
  "scripts": {
    "lint:css": "stylelint 'src/**/*.css' --config ../../.stylelintrc.json",
    "build": "npm run lint:css && npm run typecheck && tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "audit:compliance": "./scripts/generate-compliance-report.sh",
    "audit:compliance:tests": "./scripts/generate-test-compliance-report.sh",
    "test": "npm run test:split",
    "test:watch": "vitest",
    "test:coverage": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --coverage",
    "test:a11y": "NODE_OPTIONS=--max-old-space-size=8192 vitest run -t \"Accessibility\"",
    "test:a11y:watch": "vitest -t \"Accessibility\"",
    "test:components": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components",
    "test:components:panels": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/resource/panels",
    "test:components:navigation": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/navigation",
    "test:components:layout": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/layout src/components/branding",
    "test:components:misc": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/error-states src/components/loading-states src/components/modals src/components/annotation src/components/Button src/components/resource/__tests__ src/components/__tests__",
    "test:components:states": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/error-states src/components/loading-states",
    "test:components:modals:basic": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/modals/__tests__/SearchModal.basic.test.tsx",
    "test:components:modals:keyboard": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/modals/__tests__/SearchModal.keyboard.test.tsx",
    "test:components:modals:accessibility": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/modals/__tests__/SearchModal.accessibility.test.tsx",
    "test:components:modals:visual": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/modals/__tests__/SearchModal.visual.test.tsx",
    "test:components:modals": "npm run test:components:modals:basic && npm run test:components:modals:keyboard && npm run test:components:modals:accessibility && npm run test:components:modals:visual",
    "test:components:other": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/components/annotation src/components/Button src/components/resource/__tests__ src/components/__tests__",
    "test:features": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/features",
    "test:other": "NODE_OPTIONS=--max-old-space-size=8192 vitest run src/contexts src/hooks src/lib src/assets",
    "test:split": "npm run test:components:panels && npm run test:components:navigation && npm run test:components:layout && npm run test:components:states && npm run test:components:modals && npm run test:components:other && npm run test:features && npm run test:other",
    "test:split:coverage": "npm run test:coverage"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.23",
    "axe-core": "^4.11.0",
    "cssnano": "^7.1.2",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.0.0",
    "postcss-import": "^16.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "The AI Alliance",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-AI-Alliance/semiont.git",
    "directory": "packages/react-ui"
  },
  "dependencies": {
    "@semiont/api-client": "*",
    "@semiont/core": "*"
  }
}
