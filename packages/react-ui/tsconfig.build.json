{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "node_modules",
    "dist",
    "scripts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__",
    "**/__mocks__"
  ]
}
