{
  "name": "@semiont/event-sourcing",
  "version": "0.3.9",
  "description": "Event sourcing infrastructure for Semiont - EventLog, EventBus, and ViewManager",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-AI-Alliance/semiont.git",
    "directory": "packages/event-sourcing"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsup",
    "watch": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "event-sourcing",
    "event-store",
    "event-log",
    "event-bus",
    "view-manager",
    "cqrs",
    "semiont"
  ],
  "author": "Semiont Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@semiont/api-client": "*",
    "@semiont/core": "*",
    "@vitest/ui": "4.0.18",
    "nanoid": "^5.1.7",
    "uuid": "^10.0.0"
  }
}
