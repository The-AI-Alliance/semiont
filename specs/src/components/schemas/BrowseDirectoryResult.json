{
  "type": "object",
  "description": "Result of browsing a directory listing",
  "properties": {
    "correlationId": {
      "type": "string"
    },
    "response": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "./DirectoryEntry.json"
          }
        }
      },
      "required": [
        "path",
        "entries"
      ]
    }
  },
  "required": [
    "correlationId",
    "response"
  ]
}
