{
  "type": "object",
  "description": "Emitted when a mark is submitted with its annotation body",
  "properties": {
    "motivation": {
      "$ref": "./Motivation.json"
    },
    "selector": {
      "description": "One or more W3C selectors",
      "oneOf": [
        { "$ref": "./TextPositionSelector.json" },
        { "$ref": "./TextQuoteSelector.json" },
        { "$ref": "./SvgSelector.json" },
        { "$ref": "./FragmentSelector.json" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "./TextPositionSelector.json" },
              { "$ref": "./TextQuoteSelector.json" },
              { "$ref": "./SvgSelector.json" },
              { "$ref": "./FragmentSelector.json" }
            ]
          }
        }
      ]
    },
    "body": {
      "oneOf": [
        {
          "$ref": "./AnnotationBody.json",
          "description": "Single body (TextualBody or SpecificResource)"
        },
        {
          "type": "array",
          "items": { "$ref": "./AnnotationBody.json" },
          "minItems": 1,
          "description": "Non-empty array of mixed TextualBody / SpecificResource bodies"
        }
      ],
      "description": "Optional body. Omit for annotations whose motivation alone is meaningful (e.g. highlighting) or whose user-supplied content is empty (e.g. an assessing annotation saved without comment text). Shape matches Annotation.body."
    }
  },
  "required": ["motivation", "selector"]
}
