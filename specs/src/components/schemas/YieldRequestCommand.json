{
  "type": "object",
  "description": "Bus command to request yield (generation) of a new resource from an annotation.",
  "properties": {
    "correlationId": {
      "type": "string",
      "description": "Client-supplied id used to match this command to its result event(s) on the events-stream. Generated by the route handler if absent."
    },
    "annotationId": {
      "type": "string"
    },
    "resourceId": {
      "type": "string"
    },
    "options": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "temperature": {
          "type": "number"
        },
        "maxTokens": {
          "type": "integer"
        },
        "context": {
          "$ref": "./GatheredContext.json"
        },
        "storageUri": {
          "type": "string"
        }
      },
      "required": ["title", "storageUri"]
    }
  },
  "required": ["annotationId", "resourceId", "options"]
}
