{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "content": {
      "type": "string"
    },
    "format": {
      "$ref": "./ContentFormat.json"
    },
    "entityTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "language": {
      "type": "string"
    },
    "creationMethod": {
      "type": "string"
    },
    "sourceAnnotationId": {
      "type": "string"
    },
    "sourceResourceId": {
      "type": "string"
    },
    "generationPrompt": {
      "type": "string",
      "description": "Prompt used to generate this resource (for AI-generated resources)"
    },
    "generator": {
      "description": "Agent(s) that generated this resource (for AI-generated resources). Single Agent object or array of Agents.",
      "oneOf": [
        { "$ref": "./Agent.json" },
        { "type": "array", "items": { "$ref": "./Agent.json" } }
      ]
    },
    "isDraft": {
      "type": "boolean"
    }
  },
  "required": [
    "name",
    "content",
    "format",
    "entityTypes"
  ]
}