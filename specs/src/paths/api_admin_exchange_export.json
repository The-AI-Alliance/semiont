{
  "post": {
    "summary": "Export Knowledge Base",
    "description": "Export knowledge base as a full backup (tar.gz) or current-state snapshot",
    "tags": ["Admin"],
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "required": ["format"],
            "properties": {
              "format": {
                "type": "string",
                "enum": ["backup", "snapshot"],
                "description": "Export format: 'backup' for full event log + content, 'snapshot' for current-state resources"
              },
              "includeArchived": {
                "type": "boolean",
                "default": false,
                "description": "Include archived resources (snapshot format only)"
              }
            }
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "Streaming archive file",
        "content": {
          "application/gzip": {
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        }
      },
      "401": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/ErrorResponse.json"
            }
          }
        }
      },
      "403": {
        "description": "Forbidden - Admin access required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/ErrorResponse.json"
            }
          }
        }
      }
    }
  }
}
