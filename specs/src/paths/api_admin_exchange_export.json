{
  "post": {
    "summary": "Export Knowledge Base as JSON-LD",
    "description": "Export the knowledge base as a JSON-LD Linked Data tar.gz archive",
    "tags": ["Admin"],
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "parameters": [
      {
        "name": "includeArchived",
        "in": "query",
        "description": "Include archived resources in export",
        "required": false,
        "schema": {
          "type": "boolean",
          "default": false
        }
      }
    ],
    "responses": {
      "200": {
        "description": "Streaming JSON-LD archive",
        "content": {
          "application/gzip": {
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        }
      },
      "401": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/ErrorResponse.json"
            }
          }
        }
      },
      "403": {
        "description": "Forbidden - Admin access required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/ErrorResponse.json"
            }
          }
        }
      }
    }
  }
}
