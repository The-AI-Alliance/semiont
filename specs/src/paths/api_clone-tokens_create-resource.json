{
  "post": {
    "summary": "Create Resource from Clone Token",
    "description": "Create a new resource using a clone token",
    "tags": [
      "Resources"
    ],
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "../components/schemas/CreateResourceFromTokenRequest.json"
          }
        }
      }
    },
    "responses": {
      "202": {
        "description": "Resource creation accepted",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "resourceId": {
                  "type": "string"
                }
              },
              "required": ["resourceId"]
            }
          }
        }
      }
    }
  }
}