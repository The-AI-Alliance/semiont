{
  "post": {
    "summary": "Backup Knowledge Base",
    "description": "Create a lossless backup of the knowledge base as a streaming tar.gz archive",
    "tags": ["Admin"],
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "responses": {
      "200": {
        "description": "Streaming backup archive",
        "content": {
          "application/gzip": {
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        }
      },
      "401": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/ErrorResponse.json"
            }
          }
        }
      },
      "403": {
        "description": "Forbidden - Admin access required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/ErrorResponse.json"
            }
          }
        }
      }
    }
  }
}
