{
  "get": {
    "summary": "Job Assignment Stream",
    "description": "SSE stream that pushes job-available notifications to connected workers. Workers filter by job type via query parameters.",
    "tags": [
      "Worker Pool"
    ],
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "parameters": [
      {
        "schema": {
          "type": "string",
          "enum": [
            "reference-annotation",
            "generation",
            "highlight-annotation",
            "assessment-annotation",
            "comment-annotation",
            "tag-annotation"
          ]
        },
        "required": false,
        "name": "type",
        "in": "query",
        "description": "Job type(s) to receive notifications for. Repeat for multiple types. Omit to receive all types.",
        "explode": true
      }
    ],
    "responses": {
      "200": {
        "description": "SSE stream of job-available events",
        "content": {
          "text/event-stream": {
            "schema": {
              "type": "object",
              "properties": {
                "jobId": { "type": "string" },
                "type": { "type": "string" },
                "resourceId": { "type": "string" }
              },
              "required": ["jobId", "type", "resourceId"]
            }
          }
        }
      }
    }
  }
}
